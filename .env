# Source this in your shell before working on helix-lite:
#   source .env
# Or use: set -a; source .env; set +a

# Cache & venv on /snapshots (btrfs, 234 GB free, stable).
# AVOID /mnt/win-disk2: NTFS via FUSE+autofs unmounts after idle-timeout=600s
# and corrupts open file handles (broke the previous venv on 2026-05-08).
export HELIX_ROOT=/snapshots/helix-lite
export UV_CACHE_DIR=$HELIX_ROOT/uv-cache
export HF_HOME=$HELIX_ROOT/hf-cache
export TRANSFORMERS_CACHE=$HELIX_ROOT/hf-cache  # legacy alias
export HF_HUB_CACHE=$HELIX_ROOT/hf-cache/hub

# Tooling on PATH (uv installed at ~/.local/bin)
export PATH="$HOME/.local/bin:$PATH"

# vLLM / inference defaults
export VLLM_LOGGING_LEVEL=INFO
# Use only GPU 0 by default for the model; GPU 1 reserved for KV offload / EM-LLM
# Override per-script if you need both
# export CUDA_VISIBLE_DEVICES=0

# Activate the venv (lives on /snapshots/helix-lite/.venv via symlink in project)
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
if [[ -f "$PROJECT_DIR/.venv/bin/activate" ]]; then
    source "$PROJECT_DIR/.venv/bin/activate"
fi
